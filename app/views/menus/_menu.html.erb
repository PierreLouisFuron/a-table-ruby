<div id="menu_<%= menu.id %>" class="row mt-2">
  <div class="mt-2">
    <button type="button" class="btn btn-primary mb-2" data-bs-toggle="modal" data-bs-target="#menu<%= menu.id %>IngredientsListModal"><i class="fa fa-scroll me-2"></i>Ingredients</button>
    <%= button_to clear_menu_meals_path(menu), data: {turbo_confirm: 'Clear all meals ?'}, class: 'btn btn-primary mb-2', form_class: 'd-inline' do %> <i class="fa fa-broom me-2"></i>Clear Meals<% end %>
    <%= link_to menu, data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: 'btn btn-primary mb-2' do %><i class="fa fa-trash me-2"></i>Delete Menu<% end %>
  </div>
  <%= render 'shared/ingredients_list_modal', title: "Menu's Ingredients", ingredients: menu.all_ingredients, modal_id: "menu#{menu.id}IngredientsListModal" %>
  <% ingredients_by_date = menu.all_ingredients_by_date %>
  <% (menu.start_date..menu.end_date).to_a.each do |date| %>
    <%= render 'shared/ingredients_list_modal', title: "#{date.strftime("%A, %B %d")}'s Ingredients", ingredients: ingredients_by_date[date] || [], modal_id: "menu#{menu.id}Date#{date}IngredientsListModal" %>
  <% end %>
  <div class="card-group text-center">
    <% (menu.start_date..menu.end_date).to_a.each do |date| %>
      <div class="card shadow-sm">
        <div class="card-header d-flex">
          <div class="flex-grow-1 align-self-center">
            <%= date.strftime("%A, %B %d") %> 
          </div>
          <span class="dropdown">
            <button class="btn btn-outline-primary btn-sm" data-bs-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis"></i></button>
            <ul class="dropdown-menu">
              <li><%= button_to meals_path, params: { menu: menu, meal: { date: date }}, class: 'dropdown-item' do %><i class="fa fa-plus me-2"></i>Add Meal<% end %></li>
              <li><button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#menu<%= menu.id %>Date<%= date %>IngredientsListModal"><i class="fa fa-scroll me-2"></i>Ingredients</button></li>
              <%= button_to clear_day_meals_path(menu), params: {date: date}, data: {turbo_confirm: 'Clear all day meals ?'}, class: 'dropdown-item', form_class: 'd-inline' do %> <i class="fa fa-broom me-2"></i>Clear Meals<% end %>
            </ul>
          </span>
        </div>
        <div class="card-body p-0">
          <% menu.meals.where(date: date).each_with_index do |meal, index| %>
            <% if index > 0 %> <div class="mt-1"></div> <% end %>
            <%= render meal %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

