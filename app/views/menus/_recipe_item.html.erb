<li class="list-group-item p-0" > 
  <div class="d-flex justify-content-between align-items-center">
    <div class="d-flex justify-content-start align-items-center">
      <div class="ratio ratio-4x3 flex-shrink-0 me-3" style="width: 70px;">
        <%= image_tag recipe.get_tiny_cover_thumbnail, class: 'object-fit-cover', alt: 'menu' %>
      </div>
      <%= recipe.name %>
    </div>

    <%= render 'menus/recipe_toggle', meal: meal, recipe: recipe %> 
  </div>
</li>
