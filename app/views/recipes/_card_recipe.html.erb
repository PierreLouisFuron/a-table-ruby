<div class="col-md-3 col-6 mb-3">
  <%= link_to recipe, class: "card shadow-sm h-100 text-decoration-none" do %>
    <div class="ratio ratio-16x9">
      <%= image_tag recipe.get_cover_thumbnail, class: 'card-img-top object-fit-cover', alt: 'menu' %>
    </div>
    <div class="card-body">
      <h5 class="card-title text-capitalize"><%= recipe.name %></h5>
      <% recipe.tags.each do |tag| %>
        <span class="badge rounded-pill text-bg-primary"><%= tag.name %></span>
      <% end %>
      <% if recipe.sources.any? %>
        <div class="mt-3"><small class="text-muted fst-italic"><%= truncate("Source: #{recipe.sources.first.name}", length: 27, separator: '') %></small></div>
      <% end %>
    </div>
  <% end %>
</div>
